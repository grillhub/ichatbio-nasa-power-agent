[
  {
    "case_id": "enrich_1_normal_merra2",
    "description": "Normal enrich with default source (merra2), add temperature to records",
    "type": "enrich_artifact",
    "request": "Add temperature data to those records",
    "resource_file": "list_of_locations_10.json",
    "params_override": {
      "weather_parameters": ["T2M"],
      "source": "merra2"
    },
    "expected_status": "success",
    "expected_response_contains": ["enriched", "Enrichment"],
    "expected_log_contains": ["merra2"]
  },
  {
    "case_id": "enrich_2_specify_source",
    "description": "Enrich with specified source (geos5)",
    "type": "enrich_artifact",
    "request": "Add temperature data from geos5 source to those records",
    "resource_file": "list_of_locations_10.json",
    "params_override": {
      "weather_parameters": ["T2M"],
      "source": "geos5"
    },
    "expected_status": "success",
    "expected_response_contains": ["enriched", "Enrichment"],
    "expected_log_contains": ["geos5"]
  },
  {
    "case_id": "enrich_3_param_not_temperature",
    "description": "Enrich with parameter that is not explicitly 'temperature' (e.g. hot data / T2M)",
    "type": "enrich_artifact",
    "request": "Add hot data to those records",
    "resource_file": "list_of_locations_10.json",
    "params_override": {
      "weather_parameters": ["T2M"],
      "source": "merra2"
    },
    "expected_status": "success",
    "expected_response_contains": ["enriched", "Enrichment"]
  },
  {
    "case_id": "common_4_good_address",
    "description": "Common query with good address and specific date",
    "type": "common_query",
    "request": "Get the temperature in Gainesville, FL on 25 Dec 2025",
    "params_override": {},
    "expected_status": "success",
    "expected_response_contains": ["NASA POWER", "Location", "T2M"],
    "expected_log_contains": ["Gainesville", "2025-12-25"]
  },
  {
    "case_id": "common_5_unclear_gainesville",
    "description": "Common query with unclear location (Gainesville in all states)",
    "type": "common_query",
    "request": "Get the temperature in Gainesville on 25 Dec 2025",
    "params_override": {},
    "expected_status": "success",
    "expected_response_contains": ["NASA POWER", "Location"],
    "expected_log_contains": ["Gainesville"]
  },
  {
    "case_id": "common_6_invalid_city",
    "description": "Common query with non-existent city",
    "type": "common_query",
    "request": "Get the temperature in Grillville, FL on 25 Dec 2025",
    "params_override": {},
    "expected_status": "fail",
    "expected_response_contains": ["Location not found", "Grillville"],
    "expected_error_contains": ["not find", "coordinates"]
  },
  {
    "case_id": "common_7_future_date",
    "description": "Common query with future date (no data expected)",
    "type": "common_query",
    "request": "Get the temperature in Gainesville, FL on 25 Dec 2035",
    "params_override": {},
    "expected_status": "success",
    "expected_response_contains": ["NASA POWER", "Location"]
  },
  {
    "case_id": "common_8_month_only",
    "description": "Common query with no specific day (March 2020) - expect monthly average and std",
    "type": "common_query",
    "request": "Get temperature in Gainesville, FL on March 2020",
    "params_override": {},
    "expected_status": "success",
    "expected_response_contains": ["NASA POWER", "Monthly summary", "Average", "Standard deviation"],
    "expected_log_contains": ["Month YYYY", "2020-03-01"]
  },
  {
    "case_id": "common_9_month_multiple_years",
    "description": "Common query with same month across multiple years (March 2020 - 2025)",
    "type": "common_query",
    "request": "Get temperature in Gainesville, FL on March 2020 - 2025",
    "params_override": {},
    "expected_status": "success_or_fail",
    "expected_response_contains": ["NASA POWER", "Location"]
  },
  {
    "case_id": "common_10_year_only",
    "description": "Common query with year only - must ask user to specify month",
    "type": "common_query",
    "request": "Get the temperature in Gainesville, FL in 2020",
    "params_override": {},
    "expected_status": "fail",
    "expected_response_contains": ["specify at least the month", "season"]
  },
  {
    "case_id": "common_11_yyyy_mm_dd",
    "description": "Common query with YYYY-MM-DD date format",
    "type": "common_query",
    "request": "Get temperature in Gainesville, FL for 2020-03-15",
    "params_override": {},
    "expected_status": "success",
    "expected_response_contains": ["NASA POWER", "Location"],
    "expected_log_contains": ["2020-03-15"]
  },
  {
    "case_id": "enrich_list_params_only",
